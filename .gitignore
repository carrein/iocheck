.claude/*
!.claude/settings.json
!.claude/render-session.py
!.claude/plans/

# Bun / Node
node_modules/
*.tsbuildinfo

# Local tool cache (downloaded by `make up`)
.bin/

# Bench artifacts (regenerated by `make bench-*`; never committed)
artifacts/*
!artifacts/.gitkeep

# Editor + OS
.DS_Store
.vscode/
.idea/

# Env files with secrets (the repo ships only .env.example)
.env
.env.local

# Background PID files
.bench.pid
